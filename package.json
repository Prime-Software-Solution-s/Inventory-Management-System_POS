{
  "name": "inventory-pos",
  "version": "1.0.0",
  "private": true,
  "description": "Modern full-stack inventory management system",
  "engines": {
    "node": "20.x",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace client\" \"npm run dev --workspace server\"",
    "start": "npm run start --workspace server",
    "build": "npm run build --workspace server --if-present",
    "client:build": "npm run build --workspace client",
    "client:dev": "npm run dev --workspace client",
    "server:dev": "npm run dev --workspace server",
    "seed": "npm run seed --workspace server"
  },
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "mongodb": "^7.1.1"
  }
}
