# Dev default: use the same-origin `/api` path + Vite proxy.
# Production (Vercel): set this to your deployed API origin (recommended) or `/api` if you deploy API on the same domain.
# Examples:
# - `https://<railway-app>.up.railway.app` (client auto-appends `/api`)
# - `https://<railway-app>.up.railway.app/api`
VITE_API_BASE_URL=/api

# Vite dev proxy target (used in `vite.config.js`).
VITE_DEV_PROXY_TARGET=http://localhost:5001
